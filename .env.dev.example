# =========================================
# SPRING PROFILE
# =========================================
SPRING_PROFILES_ACTIVE=dev

# =========================================
# APPLICATION
# =========================================
PORT=8081

# =========================================
# POSTGRESQL
# =========================================
POSTGRES_URL=jdbc:postgresql://localhost:5432/collabrium_iam_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=1234

# =========================================
# JWT
# =========================================
JWT_SECRET=collabrium-development-secret-key-256-bits-long
JWT_ISSUER=collabrium
JWT_AUDIENCE=collabrium-platform

# =========================================
# EUREKA
# =========================================
EUREKA_URL=http://localhost:8761/eureka/

# =========================================
# RABBITMQ
# =========================================
RABBIT_HOST=localhost
RABBIT_PORT=5672
RABBIT_USER=collabrium
RABBIT_PASSWORD=collabrium
RABBIT_VIRTUAL_HOST=/

# =========================================
# LOGGING
# =========================================
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG